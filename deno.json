{
  "name": "@kaln/maestro-parallel",
  "version": "0.2.0",
  "description": "Parallel Maestro test runner with interactive device picker, automatic build/install, and JUnit aggregation. Runs Maestro flows on multiple Android and iOS devices simultaneously.",
  "license": "Apache-2.0",
  "exports": {
    ".": "./mod.ts",
    "./cli": "./cli.ts",
    "./config": "./src/config.ts"
  },
  "publish": {
    "include": [
      "mod.ts",
      "cli.ts",
      "src/**/*.ts",
      "deno.json",
      "README.md",
      "LICENSE"
    ],
    "exclude": [
      "src/**/*.test.ts",
      "examples/**",
      ".github/**"
    ]
  },
  "tasks": {
    "dev": "deno run -A cli.ts",
    "check": "deno check mod.ts cli.ts src/**/*.ts",
    "fmt": "deno fmt",
    "lint": "deno lint",
    "test": "deno test -A",
    "compile:macos-arm": "deno compile -A --target aarch64-apple-darwin -o dist/maestro-parallel-macos-arm64 cli.ts",
    "compile:macos-x86": "deno compile -A --target x86_64-apple-darwin -o dist/maestro-parallel-macos-x64 cli.ts",
    "compile:linux-x86": "deno compile -A --target x86_64-unknown-linux-gnu -o dist/maestro-parallel-linux-x64 cli.ts",
    "compile:linux-arm": "deno compile -A --target aarch64-unknown-linux-gnu -o dist/maestro-parallel-linux-arm64 cli.ts",
    "compile:all": "deno task compile:macos-arm && deno task compile:macos-x86 && deno task compile:linux-x86 && deno task compile:linux-arm"
  },
  "imports": {
    "@std/path": "jsr:@std/path@^1.0.8",
    "@std/yaml": "jsr:@std/yaml@^1.0.5",
    "@std/cli": "jsr:@std/cli@^1.0.8",
    "@std/fs": "jsr:@std/fs@^1.0.6",
    "@std/assert": "jsr:@std/assert@^1.0.9"
  },
  "fmt": {
    "lineWidth": 100,
    "singleQuote": true,
    "semiColons": true,
    "include": ["src/", "mod.ts", "cli.ts", "examples/"]
  },
  "lint": {
    "include": ["src/", "mod.ts", "cli.ts"],
    "rules": {
      "tags": ["recommended"]
    }
  }
}
