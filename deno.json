{
  "name": "@kaln/maestro-parallel",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "exports": {
    ".": "./index.ts",
    "./config": "./src/config.ts"
  },
  "tasks": {
    "run": "deno run -A cli.ts",
    "check": "deno check cli.ts index.ts src/*.ts",
    "fmt": "deno fmt",
    "lint": "deno lint"
  },
  "imports": {
    "@std/path": "jsr:@std/path@^1.0.8",
    "@std/cli": "jsr:@std/cli@^1.0.6",
    "@std/fs": "jsr:@std/fs@^1.0.5"
  },
  "fmt": {
    "lineWidth": 100,
    "singleQuote": true
  },
  "lint": {
    "rules": {
      "exclude": ["no-explicit-any"]
    }
  },
  "exclude": ["dist", "npm", "node_modules", "examples"]
}
